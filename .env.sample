# HCL Tech Onboarding Chatbot Configuration

# Hugging Face Access Token (Optional for remote models, local fallback exists)
HF_ACCESS_KEY=your_huggingface_token_here

# Together AI API Key (Optional, for dataset generation)
TOGETHER_API_KEY=your_together_api_key_here

# Groq API Key (For LLM responses, local fallback displays raw chunks)
GROQ_API_KEY=your_groq_api_key_here


# Server Settings
FLASK_PORT=5000
FLASK_ENV=development
